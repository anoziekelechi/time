FROM python:3.12-slim-bookworm AS builder
LABEL maintainer="Anozie Kelechi"
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

RUN apt update && \
    apt install  -y --no-install-recommends \
        libpq-dev gcc ca-certificates libssl-dev pkg-config libmagic1 && \
    rm -rf /var/lib/apt/lists/*

COPY --from=ghcr.io/astral-sh/uv:latest /uv /bin/uv 

WORKDIR /app

# only alembic and readme needs multiple line copy ./alembic
COPY alembic ./alembic
COPY alembic.ini ./alembic.ini
COPY pyproject.toml uv.lock README.md ./
COPY api ./api

# # install system wide
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-install-project   


RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen

#_____ FINAL BUILD _______

FROM python:3.12-slim-bookworm
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1
RUN apt update && \
    apt install -y --no-install-recommends libpq-dev && \
    rm -rf /var/lib/apt/lists/*
    
WORKDIR /app
COPY --from=builder /bin/uv /bin/uv
COPY --from=builder /usr/local/lib/python3.12/site-packages /usr/local/lib/python3.12/site-packages/
COPY --from=builder /usr/local/bin /usr/local/bin

RUN useradd -ms /bin/bash anozie && \
    chown -R anozie /app
    

COPY --chown=anozie:anozie api/ ./api/ 
USER anozie
EXPOSE 8000
CMD [ "uv", "run", "uvicorn", "api.main:app","--host", "0.0.0.0", "--port", "8000" ]
